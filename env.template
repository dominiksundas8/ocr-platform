# === DATABASE SETTINGS ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ocr_db

# === DJANGO BACKEND SETTINGS ===
# Use 'django-insecure-...' or generate a new secret
DJANGO_SECRET_KEY=TUO_DJANGO_SECRET_QUI
DJANGO_DEBUG=True
DATABASE_URL=postgres://postgres:postgres@db:5432/ocr_db
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0

# === NEXT.JS FRONTEND SETTINGS ===
# In development use http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=TUO_NEXTAUTH_SECRET_QUI

# === EXTERNAL SERVICES ===
# --- MongoDB (Polyglot Storage & Hardened) ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=adminpass_super_secret
MONGO_APP_USER=ocr_user
MONGO_APP_PASS=app_password_vault
MONGO_URI=mongodb://ocr_user:app_password_vault@mongodb:27017/ocr_vault
MONGO_DB_NAME=ocr_vault

# --- Altre Variabili ---
# Ottieni la chiave su https://aistudio.google.com/
GEMINI_API_KEY=AIzaSy...

# Configurazione Microservizi
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
BACKEND_URL=http://backend:8000
FASTAPI_OCR_URL=http://ocr_service:8001/extract
CELERY_BROKER_URL=redis://redis:6379/0

# Segreto condiviso interno Django <-> FastAPI (genera una stringa casuale sicura)
INTERNAL_API_SECRET=GENERA_UNA_STRINGA_CASUALE_QUI
